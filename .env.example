# =============================================================================
# Aegis Stack — Variáveis de Ambiente
# =============================================================================
# NUNCA versione o ficheiro .env com credenciais reais.
# Para fazer deploy: bash deploy.sh  (valida e preenche interactivamente)
# =============================================================================

# ── Identidade do Nó ──────────────────────────────────────────────────────
# Nome do nó no Tailscale. Letras minúsculas, números e hífens.
CLIENT_NAME=meu-servidor-01

# ── Tailscale ─────────────────────────────────────────────────────────────
# Tailscale Admin → Settings → Keys → Generate auth key
# Marcar: Reusable ✓
TS_AUTHKEY=

# Sub-rede local a anunciar para a tailnet.
TAILSCALE_ROUTES=192.168.1.0/24

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────
# Zero Trust → Networks → Tunnels → (túnel) → copiar token após --token
CF_TOKEN=

# ── RustDesk Server ───────────────────────────────────────────────────────
# Domínio ou IP do VPS. O registo DNS deve ser grey-cloud (sem proxy CF).
RUSTDESK_RELAY_HOST=papermoon.cloud

# ── Versões das Imagens ────────────────────────────────────────────────────
TAILSCALE_VERSION=v1.98.4
CLOUDFLARED_VERSION=2026.6.1
RUSTDESK_VERSION=1.1.15
